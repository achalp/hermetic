  "root": "root",
  "elements": {
    "root": {
      "type": "LayoutColumn",
      "props": { "gap": 16 },
      "children": ["heading", "dataCtrl"]
    },
    "heading": {
      "type": "TextBlock",
      "props": { "content": "Product Inventory Dashboard", "variant": "heading" }
    },
    "dataCtrl": {
      "type": "DataController",
      "props": {
        "source": { "statePath": "/datasets/main" },
        "filters": [
          {
            "key": "Brand",
            "column": "Brand",
            "bindTo": "/filters/Brand",
            "label": "Brand",
            "allowAll": true,
            "dependsOn": null
          },
          {
            "key": "Category",
            "column": "Category",
            "bindTo": "/filters/Category",
            "label": "Category",
            "allowAll": true,
            "dependsOn": null
          }
        ],
        "pipeline": [
          { "op": "filter" },
          {
            "op": "groupBy",
            "columns": ["Brand"],
            "aggregations": [{ "column": "Price", "fn": "sum", "as": "TotalInventoryCost" }]
          },
          { "op": "sort", "column": "TotalInventoryCost", "direction": "desc" }
        ],
        "outputs": [{ "statePath": "/computed/costByBrand", "format": null }]
      },
      "children": ["statsGrid", "barChart", "catChart"]
    },
    "statsGrid": {
      "type": "LayoutGrid",
      "props": { "columns": 3, "gap": 16 },
      "children": ["stat1", "stat2", "stat3"]
    },
    "stat1": {
      "type": "StatCard",
      "props": {
        "label": "Total Products",
        "value": "10",
        "change": null,
        "trend": null,
        "description": "Unique items"
      }
    },
    "stat2": {
      "type": "StatCard",
      "props": {
        "label": "Average Price",
        "value": "$51.85",
        "change": null,
        "trend": null,
        "description": "Mean product price"
      }
    },
    "stat3": {
      "type": "StatCard",
      "props": {
        "label": "Total Stock",
        "value": "2,290",
        "change": null,
        "trend": null,
        "description": "Units in inventory"
      }
    },
    "barChart": {
      "type": "BarChart",
      "props": {
        "title": "Inventory Cost by Brand",
        "data": { "$state": "/computed/costByBrand" },
        "x_key": "Brand",
        "y_keys": ["TotalInventoryCost"],
        "orientation": "horizontal",
        "stacked": false,
        "color_map": { "TotalInventoryCost": "indigo" }
      }
    },
    "catChart": {
      "type": "BarChart",
      "props": {
        "title": "Inventory Cost by Category",
        "data": { "$state": "/computed/costByCategory" },
        "x_key": "Category",
        "y_keys": ["TotalInventoryCost"],
        "orientation": "vertical",
        "stacked": false,
        "color_map": { "TotalInventoryCost": "emerald" }
      }
    }
  }
}
