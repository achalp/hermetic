# ─── LLM Provider ───────────────────────────────────────
# Pick ONE provider. Credentials are auto-detected if LLM_PROVIDER is not set.
# LLM_PROVIDER=anthropic        # or: bedrock, vertex, openai-compatible

# Option A: Anthropic (direct API)
# Get your API key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Option B: Amazon Bedrock
# Uses AWS credentials (access key or profile-based auth)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# Option C: Google Vertex AI
# Uses Google Cloud Application Default Credentials
# GOOGLE_VERTEX_PROJECT=your-gcp-project-id
# GOOGLE_VERTEX_LOCATION=us-east5

# Option D: OpenAI-Compatible (Ollama, LM Studio, vLLM, etc.)
# Any endpoint that implements the OpenAI chat completions API
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=                  # optional — not needed for Ollama
# OPENAI_MODEL=llama3.3            # required — the model served by your endpoint

# ─── Sandbox Runtime ───────────────────────────────────
# Sandbox runtime: "docker" (default), "e2b" (cloud), or "microsandbox" (microvm)
SANDBOX_RUNTIME=docker

# E2B cloud sandbox (only needed if SANDBOX_RUNTIME=e2b)
# E2B_API_KEY=

# Microsandbox (only needed if SANDBOX_RUNTIME=microsandbox)
# MICROSANDBOX_URL=http://127.0.0.1:5555
# MICROSANDBOX_API_KEY=
# MICROSANDBOX_IMAGE=              # default: microsandbox/python (packages installed during startup)

# ─── Data Warehouse (optional) ──────────────────────────
# Pre-configure a warehouse connection so you don't have to enter credentials every time.
# Uncomment ONE section below. Credentials are loaded into the connect form automatically.

# Option A: PostgreSQL (also works with Redshift, AlloyDB, Neon, Supabase)
# WAREHOUSE_TYPE=postgresql
# WAREHOUSE_PG_HOST=localhost
# WAREHOUSE_PG_PORT=5432
# WAREHOUSE_PG_DATABASE=mydb
# WAREHOUSE_PG_USER=postgres
# WAREHOUSE_PG_PASSWORD=
# WAREHOUSE_PG_SCHEMA=public
# WAREHOUSE_PG_SSL=false

# Option B: Google BigQuery
# WAREHOUSE_TYPE=bigquery
# WAREHOUSE_BQ_PROJECT=my-gcp-project
# WAREHOUSE_BQ_DATASET=my_dataset
# WAREHOUSE_BQ_CREDENTIALS_JSON=   # paste the full JSON key or path to a .json file

# Option C: ClickHouse
# WAREHOUSE_TYPE=clickhouse
# WAREHOUSE_CH_HOST=play.clickhouse.com
# WAREHOUSE_CH_PORT=8123
# WAREHOUSE_CH_DATABASE=default
# WAREHOUSE_CH_USER=default
# WAREHOUSE_CH_PASSWORD=
# WAREHOUSE_CH_SSL=false
