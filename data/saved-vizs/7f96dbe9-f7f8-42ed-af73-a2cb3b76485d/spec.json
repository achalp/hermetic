{
  "root": "main",
  "elements": {
    "main": {
      "type": "LayoutColumn",
      "props": {
        "gap": 24
      },
      "children": [
        "heading",
        "form-container"
      ]
    },
    "heading": {
      "type": "TextBlock",
      "props": {
        "content": "Add New Flight Route",
        "variant": "heading"
      }
    },
    "form-container": {
      "type": "FormController",
      "props": {
        "fields": [
          {
            "name": "origin_city",
            "label": "Origin City",
            "type": "text",
            "required": true
          },
          {
            "name": "origin_lat",
            "label": "Origin Latitude",
            "type": "number",
            "required": true
          },
          {
            "name": "origin_lng",
            "label": "Origin Longitude",
            "type": "number",
            "required": true
          },
          {
            "name": "dest_city",
            "label": "Destination City",
            "type": "text",
            "required": true
          },
          {
            "name": "dest_lat",
            "label": "Destination Latitude",
            "type": "number",
            "required": true
          },
          {
            "name": "dest_lng",
            "label": "Destination Longitude",
            "type": "number",
            "required": true
          },
          {
            "name": "passengers",
            "label": "Passengers",
            "type": "number",
            "required": true
          },
          {
            "name": "airline",
            "label": "Airline",
            "type": "text",
            "required": true
          }
        ],
        "submit": {
          "endpoint": "/api/flights",
          "method": "POST",
          "onSuccessStatePath": "/submitSuccess",
          "onErrorStatePath": "/submitError"
        }
      },
      "children": [
        "origin-section",
        "origin-coords",
        "dest-section",
        "dest-coords",
        "flight-details",
        "success-message",
        "error-message"
      ]
    },
    "origin-section": {
      "type": "TextBlock",
      "props": {
        "content": "Origin Information",
        "variant": "heading"
      }
    },
    "origin-coords": {
      "type": "LayoutRow",
      "props": {
        "gap": 16
      },
      "children": [
        "origin-city",
        "origin-lat",
        "origin-lng"
      ]
    },
    "origin-city": {
      "type": "TextInput",
      "props": {
        "label": "Origin City",
        "value": {
          "$bindState": "/form/origin_city"
        },
        "type": "text",
        "placeholder": "e.g., New York, London, Tokyo"
      }
    },
    "origin-lat": {
      "type": "NumberInput",
      "props": {
        "label": "Origin Latitude",
        "value": {
          "$bindState": "/form/origin_lat"
        },
        "min": -90,
        "max": 90,
        "step": 0.0001
      }
    },
    "origin-lng": {
      "type": "NumberInput",
      "props": {
        "label": "Origin Longitude",
        "value": {
          "$bindState": "/form/origin_lng"
        },
        "min": -180,
        "max": 180,
        "step": 0.0001
      }
    },
    "dest-section": {
      "type": "TextBlock",
      "props": {
        "content": "Destination Information",
        "variant": "heading"
      }
    },
    "dest-coords": {
      "type": "LayoutRow",
      "props": {
        "gap": 16
      },
      "children": [
        "dest-city",
        "dest-lat",
        "dest-lng"
      ]
    },
    "dest-city": {
      "type": "TextInput",
      "props": {
        "label": "Destination City",
        "value": {
          "$bindState": "/form/dest_city"
        },
        "type": "text",
        "placeholder": "e.g., Paris, Dubai, Singapore"
      }
    },
    "dest-lat": {
      "type": "NumberInput",
      "props": {
        "label": "Destination Latitude",
        "value": {
          "$bindState": "/form/dest_lat"
        },
        "min": -90,
        "max": 90,
        "step": 0.0001
      }
    },
    "dest-lng": {
      "type": "NumberInput",
      "props": {
        "label": "Destination Longitude",
        "value": {
          "$bindState": "/form/dest_lng"
        },
        "min": -180,
        "max": 180,
        "step": 0.0001
      }
    },
    "flight-details": {
      "type": "LayoutRow",
      "props": {
        "gap": 16
      },
      "children": [
        "passengers",
        "airline"
      ]
    },
    "passengers": {
      "type": "NumberInput",
      "props": {
        "label": "Passengers",
        "value": {
          "$bindState": "/form/passengers"
        },
        "min": 0,
        "step": 1
      }
    },
    "airline": {
      "type": "TextInput",
      "props": {
        "label": "Airline",
        "value": {
          "$bindState": "/form/airline"
        },
        "type": "text",
        "placeholder": "e.g., Emirates, Delta, Singapore Airlines"
      }
    },
    "success-message": {
      "type": "Annotation",
      "props": {
        "icon": "check",
        "title": "Success",
        "content": "Flight route added successfully!",
        "severity": "success"
      },
      "visible": {
        "$state": "/submitSuccess"
      }
    },
    "error-message": {
      "type": "Annotation",
      "props": {
        "icon": "alert",
        "title": "Error",
        "content": "Failed to add flight route. Please try again.",
        "severity": "error"
      },
      "visible": {
        "$state": "/submitError"
      }
    }
  },
