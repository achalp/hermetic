{
  "root": "main",
  "elements": {
    "main": {
      "type": "LayoutColumn",
      "props": {
        "gap": 24
      },
      "children": [
        "heading",
        "key-metrics",
        "map-section",
        "category-analysis",
        "revenue-insights",
        "top-performers",
        "correlation-insight"
      ]
    },
    "heading": {
      "type": "TextBlock",
      "props": {
        "content": "San Francisco Business Location Analysis: Key Insights & Geographic Distribution",
        "variant": "heading"
      },
      "children": []
    },
    "key-metrics": {
      "type": "LayoutGrid",
      "props": {
        "columns": 4,
        "gap": 16
      },
      "children": [
        "metric-total-revenue",
        "metric-avg-revenue",
        "metric-avg-rating",
        "metric-locations"
      ]
    },
    "metric-total-revenue": {
      "type": "StatCard",
      "props": {
        "label": "Total Revenue",
        "value": "$7.31M",
        "description": "Across 30 locations"
      },
      "children": []
    },
    "metric-avg-revenue": {
      "type": "StatCard",
      "props": {
        "label": "Avg Revenue per Location",
        "value": "$244K",
        "description": "Mean across all categories"
      },
      "children": []
    },
    "metric-avg-rating": {
      "type": "StatCard",
      "props": {
        "label": "Average Rating",
        "value": "4.36",
        "trend": "up",
        "description": "Strong customer satisfaction"
      },
      "children": []
    },
    "metric-locations": {
      "type": "StatCard",
      "props": {
        "label": "Total Locations",
        "value": "30",
        "description": "5 business categories"
      },
      "children": []
    },
    "map-section": {
      "type": "LayoutColumn",
      "props": {
        "gap": 12
      },
      "children": ["map-title", "map-view", "map-annotation"]
    },
    "map-title": {
      "type": "TextBlock",
      "props": {
        "content": "Geographic Distribution of Business Locations",
        "variant": "heading"
      },
      "children": []
    },
    "map-view": {
      "type": "MapView",
      "props": {
        "title": "San Francisco Business Locations by Revenue & Category",
        "markers": {
          "$state": "/mapMarkers"
        },
        "height": 500
      },
      "children": []
    },
    "map-annotation": {
      "type": "Annotation",
      "props": {
        "icon": "info",
        "title": "Geographic Clustering",
        "content": "High-revenue restaurants cluster in tourist areas (Fisherman's Wharf, North Beach) while cafes and retail spread across residential neighborhoods. The northern waterfront shows the highest concentration of premium businesses.",
        "severity": "info"
      },
      "children": []
    },
    "category-analysis": {
      "type": "LayoutColumn",
      "props": {
        "gap": 12
      },
      "children": ["category-title", "category-charts"]
    },
    "category-title": {
      "type": "TextBlock",
      "props": {
        "content": "Revenue & Performance by Business Category",
        "variant": "heading"
      },
      "children": []
    },
    "category-charts": {
      "type": "LayoutRow",
      "props": {
        "gap": 16
      },
      "children": ["category-revenue-chart", "category-distribution-chart"]
    },
    "category-revenue-chart": {
      "type": "BarChart",
      "props": {
        "title": "Total Revenue by Category",
        "data": {
          "$state": "/categoryRevenue"
        },
        "x_key": "category",
        "y_keys": ["revenue"],
        "orientation": "horizontal",
        "color_map": {
          "revenue": "indigo"
        }
      },
      "children": []
    },
    "category-distribution-chart": {
      "type": "PieChart",
      "props": {
        "title": "Location Count by Category",
        "data": {
          "$state": "/categoryDistribution"
        },
        "show_labels": true,
        "show_legend": true,
        "colors": ["#10b981", "#f59e0b", "#06b6d4", "#ec4899", "#8b5cf6"]
      },
      "children": []
    },
    "revenue-insights": {
      "type": "LayoutColumn",
      "props": {
        "gap": 12
      },
      "children": ["revenue-title", "revenue-scatter", "revenue-annotation"]
    },
    "revenue-title": {
      "type": "TextBlock",
      "props": {
        "content": "Revenue vs. Customer Engagement Analysis",
        "variant": "heading"
      },
      "children": []
    },
    "revenue-scatter": {
      "type": "ScatterChart",
      "props": {
        "title": "Revenue vs. Reviews by Category",
        "data": {
          "$state": "/revenueRatingScatter"
        },
        "x_label": "Number of Reviews",
        "y_label": "Revenue ($)",
        "color_by": "category",
        "show_regression": true
      },
      "children": []
    },
    "revenue-annotation": {
      "type": "Annotation",
      "props": {
        "icon": "trend",
        "title": "Strong Revenue-Review Correlation",
        "content": "Analysis reveals a 0.90 correlation between revenue and review count, indicating that customer engagement (measured by reviews) is a powerful predictor of business success. Restaurants show the strongest pattern, with high-traffic locations generating both more reviews and higher revenue.",
        "severity": "success"
      },
      "children": []
    },
    "top-performers": {
      "type": "LayoutColumn",
      "props": {
        "gap": 12
      },
      "children": ["top-performers-title", "top-performers-tables"]
    },
    "top-performers-title": {
      "type": "TextBlock",
      "props": {
        "content": "Top Performing Locations",
        "variant": "heading"
      },
      "children": []
    },
    "top-performers-tables": {
      "type": "LayoutRow",
      "props": {
        "gap": 16
      },
      "children": ["top-revenue-table", "top-rated-table"]
    },
    "top-revenue-table": {
      "type": "DataTable",
      "props": {
        "caption": "Top 5 by Revenue",
        "columns": ["Business", "Category", "Revenue", "Rating"],
        "rows": {
          "$state": "/topRevenueRows"
        },
        "highlight_max": true
      },
      "children": []
    },
    "top-rated-table": {
      "type": "DataTable",
      "props": {
        "caption": "Top 5 by Rating",
        "columns": ["Business", "Category", "Rating", "Reviews"],
        "rows": {
          "$state": "/topRatedRows"
        },
        "highlight_max": true
      },
      "children": []
    },
    "correlation-insight": {
      "type": "Annotation",
      "props": {
        "icon": "alert",
        "title": "Key Strategic Insight",
        "content": "Restaurants dominate revenue (47% of total) despite representing only 30% of locations. Average restaurant revenue ($378K) is 2.7x the overall average. However, fitness businesses achieve the highest customer satisfaction (4.63 avg rating), suggesting opportunity for premium positioning in that category.",
        "severity": "info"
      },
      "children": []
    }
  },
