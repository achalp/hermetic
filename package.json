{
  "name": "hermetic",
  "version": "0.1.0",
  "description": "Upload CSV/Excel files, ask questions in natural language, get interactive dashboards powered by Claude",
  "license": "MIT",
  "author": "Hermetic Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/achalp/hermetic.git"
  },
  "keywords": [
    "csv",
    "data-visualization",
    "dashboard",
    "claude",
    "llm",
    "generative-ui",
    "next.js"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "analyze": "ANALYZE=true next build",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
